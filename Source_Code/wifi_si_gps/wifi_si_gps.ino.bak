#include <WiFi.h>
#include "wifi_utils.h"

WiFi_Utils wifiUtils(true); // Initialize WiFi_Utils with random MAC enabled

// Configuration
const char* TARGET_SSID = "Radu 55";    // Your A55 hotspot name
const char* WIFI_PASSWORD = "123456789";          // Enter your hotspot password here
const int MAX_CONNECT_ATTEMPTS = 20;
const int CONNECT_DELAY_MS = 500;

void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("\n=================================");
  Serial.println("  ESP32-S3 WiFi Network Scanner");
  Serial.println("  Target: Radu 55 Hotspot");
  Serial.println("=================================\n");

  // Step 1: Scan for networks
  WiFi.mode(WIFI_STA);
  Serial.println("📡 Scanning for WiFi networks...\n");
  
  wifiData wifiList = wifiUtils.scanWifiList();
  Serial.printf("✓ Found %d networks\n\n", wifiList.num);

  // Step 2: Find A55 hotspot
  String targetSSID = TARGET_SSID;
  uint8_t targetBSSID[6];
  int targetChannel = 0;
  float targetRSSI = 0;
  bool found = false;

  Serial.println("--- All Networks ---");
  for (int i = 0; i < wifiList.num; i++) {
    String ssid = String(wifiList.ssid[i].c_str());
    Serial.printf("%d. SSID: %s | MAC: %s | Ch: %d | RSSI: %.0f dBm\n", 
                  i+1, ssid.c_str(), wifiList.bssid[i].c_str(), 
                  wifiList.channel[i], wifiList.signal[i]);

    // Check if this is our target
    if (ssid == targetSSID) {
      Serial.println("\n🎯 Target 'Radu 55' Hotspot Found!");
      
      // Store MAC address
      const char* bssidStr = wifiList.bssid[i].c_str();
      sscanf(bssidStr, "%hhx:%hhx:%hhx:%hhx:%hhx:%hhx",
             &targetBSSID[0], &targetBSSID[1], &targetBSSID[2],
             &targetBSSID[3], &targetBSSID[4], &targetBSSID[5]);
      
      targetChannel = wifiList.channel[i];
      targetRSSI = wifiList.signal[i];
      found = true;
    }
  }
  Serial.println("--------------------\n");

  if (!found) {
    Serial.println("❌ Radu 55 hotspot not found in scan results!");
    Serial.println("Please check:");
    Serial.println("  1. Radu 55 hotspot is turned on");
    Serial.println("  2. SSID name is correct (case-sensitive)");
    Serial.println("  3. Hotspot is in range");
    return;
  }

  // Step 3: Display MAC address
  Serial.println("=== Radu 55 Network Information ===");
  Serial.printf("SSID:     %s\n", TARGET_SSID);
  Serial.printf("MAC:      %02X:%02X:%02X:%02X:%02X:%02X\n", 
                targetBSSID[0], targetBSSID[1], targetBSSID[2],
                targetBSSID[3], targetBSSID[4], targetBSSID[5]);
  Serial.printf("Channel:  %d\n", targetChannel);
  Serial.printf("RSSI:     %.0f dBm\n", targetRSSI);

  // Step 4: Connect to get IP information
  Serial.println("\n🔌 Connecting to Radu 55 hotspot...");
  
  if (strlen(WIFI_PASSWORD) == 0) {
    Serial.println("⚠️  WARNING: WiFi password not set!");
    Serial.println("Please update WIFI_PASSWORD in the code to connect.");
    return;
  }

  bool connected = wifiUtils.connectToWifi(
    std::string(TARGET_SSID),
    std::string(WIFI_PASSWORD),
    "ESP32-S3-Scanner",
    MAX_CONNECT_ATTEMPTS,
    CONNECT_DELAY_MS
  );

  if (connected) {
    Serial.println("✓ Connected successfully!\n");
    
    // Get IP information
    IPAddress localIP = WiFi.localIP();
    IPAddress gatewayIP = WiFi.gatewayIP();
    IPAddress subnetMask = WiFi.subnetMask();
    IPAddress dns = WiFi.dnsIP();

    Serial.println("=== IP Configuration ===");
    Serial.printf("ESP32 IP:     %s\n", localIP.toString().c_str());
    Serial.printf("Gateway IP:   %s  ← (Router/AP IP)\n", gatewayIP.toString().c_str());
    Serial.printf("Subnet Mask:  %s\n", subnetMask.toString().c_str());
    Serial.printf("DNS Server:   %s\n", dns.toString().c_str());
    Serial.println("========================\n");

    Serial.println("✅ Network information extracted successfully!");
    
  } else {
    Serial.println("❌ Failed to connect to Radu 55 hotspot");
    Serial.println("Please check the password and try again.");
  }

  Serial.println("\n=================================");
  Serial.println("Setup complete. Ready for testing.");
  Serial.println("=================================");
}

void loop() {
  // Main loop - network info already displayed in setup
  delay(1000);
}
